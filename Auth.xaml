<Window x:Class="Seleznev2702Test.Auth"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Seleznev2702Test"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="Auth" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Label Grid.Column="1" Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20">Авторизация пользователя</Label>
        <Label Grid.Row="1" Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center">Логин:</Label>
        <TextBox Name="LoginTB" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Width="150"></TextBox>
        <Label Grid.Row="1" Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,97,0,0">Пароль:</Label>
        <TextBox Name="PasswordTB" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Top" Width="150" Margin="0,101,0,0"></TextBox>
        <Button Name="LoginBtn" FontSize="16" Width="100" Height="50" Grid.Column="1" Content="Войти" HorizontalAlignment="Center" Grid.Row="2" VerticalAlignment="Center" Click="LoginBtn_Click"/>
    </Grid>
</Window>
