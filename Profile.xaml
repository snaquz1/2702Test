<Window x:Class="Seleznev2702Test.Profile"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterScreen"
        Title="Profile" Height="500" Width="800"
        Background="#F3F3F3">
    <Grid>
        <Border Background="White"
                CornerRadius="12"
                Padding="30"
                Width="700"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Фото -->
                <StackPanel Grid.Column="0"
                            HorizontalAlignment="Center">
                    <Button Name="ChangeAvatarBtn" Click="ChangeAvatarBtn_Click">Изменить аватарку</Button>
                    <Image Source="{Binding AvatarPath}" Name="Avatar" Width="180"
                           Height="180"
                           />

                    <TextBlock Text="Профиль"
                               FontSize="20"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Данные -->
                <Grid Grid.Column="1" Margin="30,0,0,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">

                        <TextBlock Text="Фамилия"
                                   FontWeight="SemiBold"
                                   Margin="0,10,0,2"/>
                        <TextBlock Name="SurnameTBL"
                                   FontSize="15"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Имя"
                                   FontWeight="SemiBold"
                                   Margin="0,10,0,2"/>
                        <TextBlock Name="NameTBL"
                                   FontSize="15"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Отчество"
                                   FontWeight="SemiBold"
                                   Margin="0,10,0,2"/>
                        <TextBlock Name="PatronymicTBL"
                                   FontSize="15"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Пол"
                                   FontWeight="SemiBold"
                                   Margin="0,10,0,2"/>
                        <TextBlock Name="GenderTBL"
                                   FontSize="15"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">

                        <TextBlock Text="Возраст"
                                   FontWeight="SemiBold"
                                   Margin="0,10,0,2"/>
                        <TextBlock Name="AgeTBL"
                                   FontSize="15"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Email"
                                   FontWeight="SemiBold"
                                   Margin="0,10,0,2"/>
                        <TextBlock Name="EmailTBL"
                                   FontSize="15"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Роль"
                                   FontWeight="SemiBold"
                                   Margin="0,10,0,2"/>
                        <TextBlock Name="RoleTBL"
                                   FontSize="15"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Должность"
                                   FontWeight="SemiBold"
                                   Margin="0,10,0,2"/>
                        <TextBlock Name="PositionTBL"
                                   FontSize="15"/>
                    </StackPanel>

                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>