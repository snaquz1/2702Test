<Window x:Class="Seleznev2702Test.Profile"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterScreen"
        Title="Профиль пользователя" Height="500" Width="800"
        Background="#F3F3F3">
    <Grid>
        <TabControl>
            <TabItem Header="Профиль пользователя">
                
            
        <Border Background="White"
                CornerRadius="12"
                Padding="30"
                Width="700"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                
                <StackPanel Grid.Column="0"
                            HorizontalAlignment="Center">
                    <Button Name="ChangeAvatarBtn" Click="ChangeAvatarBtn_Click">Изменить аватарку</Button>
                    <Image Source="{Binding AvatarPath}" Name="Avatar" Width="180"
                           Height="180"
                           />

                    <TextBlock Text="Профиль"
                               FontSize="20"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                            <Button Name="LogoutBtn" HorizontalAlignment="Left" Margin="10" Width="107" Background="Red" Foreground="White" Click="LogoutBtn_Click">Выйти из аккаунта</Button>
                </StackPanel>

                <Grid Grid.Column="1" Margin="30,0,0,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">

                        <TextBlock Text="Фамилия"
                                   FontWeight="SemiBold"
                                   Margin="0,10,0,2"/>
                        <TextBlock Name="SurnameTBL"
                                   FontSize="15"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Имя"
                                   FontWeight="SemiBold"
                                   Margin="0,10,0,2"/>
                        <TextBlock Name="NameTBL"
                                   FontSize="15"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Отчество"
                                   FontWeight="SemiBold"
                                   Margin="0,10,0,2"/>
                        <TextBlock Name="PatronymicTBL"
                                   FontSize="15"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Пол"
                                   FontWeight="SemiBold"
                                   Margin="0,10,0,2"/>
                        <TextBlock Name="GenderTBL"
                                   FontSize="15"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">

                        <TextBlock Text="Возраст"
                                   FontWeight="SemiBold"
                                   Margin="0,10,0,2"/>
                        <TextBlock Name="AgeTBL"
                                   FontSize="15"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Email"
                                   FontWeight="SemiBold"
                                   Margin="0,10,0,2"/>
                        <TextBlock Name="EmailTBL"
                                   FontSize="15"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Роль"
                                   FontWeight="SemiBold"
                                   Margin="0,10,0,2"/>
                        <TextBlock Name="RoleTBL"
                                   FontSize="15"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Должность"
                                   FontWeight="SemiBold"
                                   Margin="0,10,0,2"/>
                        <TextBlock Name="PositionTBL"
                                   FontSize="15"/>
                    </StackPanel>

                </Grid>
            </Grid>
        </Border>
            </TabItem>
            <TabItem Header="Все пользователи">
                <DataGrid Name="AllUsersDG" AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Имя" Binding="{Binding Name}"/>
                        <DataGridTextColumn Header="Фамилия" Binding="{Binding Surname}"/>
                        <DataGridTextColumn Header="Отчество" Binding="{Binding Patronymic}"/>
                        <DataGridTextColumn Header="Возраст" Binding="{Binding Age}"/>
                        <DataGridTextColumn Header="Логин" Binding="{Binding Login}"/>
                        <DataGridTextColumn Header="Эл почта" Binding="{Binding Email}"/>
                        <DataGridTextColumn Header="Пол" Binding="{Binding Gender}"/>
                        <DataGridTextColumn Header="Должность" Binding="{Binding PositionName}"/>
                        <DataGridTextColumn Header="Роль в системе" Binding="{Binding RoleName}"/>
                        
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>